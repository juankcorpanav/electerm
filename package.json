{
  "name": "electerm",
  "version": "1.0.0",
  "description": "Terminal/ssh/sftp client(linux, mac, win)",
  "main": "src/app/entry/entry.js",
  "scripts": {
    "start": "electron .",
    "dev": "cross-env NODE_ENV=development electron .",
    "build": "node build/build.js",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "test": "jest --forceExit",
    "test:e2e": "jest --config jest.e2e.config.js --forceExit",
    "lint": "eslint src --ext .js,.jsx",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "terminal",
    "ssh",
    "sftp",
    "electron",
    "electerm"
  ],
  "author": "electerm contributors",
  "license": "MIT",
  "homepage": "https://electerm.html5beta.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/electerm/electerm.git"
  },
  "dependencies": {
    "@xterm/xterm": "^5.3.0",
    "@xterm/addon-fit": "^0.8.0",
    "@xterm/addon-search": "^0.13.0",
    "@xterm/addon-web-links": "^0.9.0",
    "antd": "^5.12.0",
    "lodash": "^4.17.21",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ssh2": "^1.15.0",
    "node-pty": "^1.0.0",
    "nedb": "^1.8.0",
    "axios": "^1.6.0",
    "dayjs": "^1.11.10",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "babel-loader": "^9.1.3",
    "@babel/core": "^7.23.5",
    "@babel/preset-env": "^7.23.5",
    "@babel/preset-react": "^7.23.3",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "jest": "^29.7.0",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3"
  },
  "build": {
    "appId": "com.electerm.electerm",
    "productName": "electerm",
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "category": "Development"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
